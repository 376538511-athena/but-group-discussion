# ============ 生产环境配置 ============
# 复制此文件为 .env.production 并修改所有值

# 数据库（务必修改密码）
DB_NAME=seminar_papers
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# JWT 密钥（务必修改为随机字符串）
# 生成方法: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_RANDOM_STRING_1
JWT_REFRESH_SECRET=CHANGE_ME_RANDOM_STRING_2

# 前端访问地址（用于 CORS）
CLIENT_URL=https://your-domain.com

# 服务端口（Nginx 对外端口）
PORT=80

# 文件大小限制（字节，默认 50MB）
MAX_FILE_SIZE=52428800
